# Day 8 distilled-student LoRA run on Llama-3.1-8B-Instruct.
#
# Default: all three styles. If queue pressure is bad, submit the balanced-only
# abstract-safe variant:
#   bsub -env "all,STYLES=balanced,DATA_OUT=sft_8b/results/day8_sft_data_balanced,TRAIN_OUT=sft_8b/results/day8_lora_run_balanced" \
#        < sft_8b/scripts/run_day8_sft_train.lsf

set -eo pipefail

REPO_ROOT="/sc/arion/projects/lin_lab/complexbehavior/CaSino"
cd "$REPO_ROOT"

mkdir -p sft_8b/results/lsf

unset PYTHONPATH
set +u
source /hpc/packages/minerva-rocky9/miniforge3/26.1.1-3/miniforge/etc/profile.d/conda.sh
conda activate casino
set -u
hash -r

CASINO_PY=/sc/arion/work/cuiz02/conda-envs/envs/casino/bin/python

export HF_HOME=/sc/arion/scratch/cuiz02/hf_cache
export TRANSFORMERS_CACHE=$HF_HOME/transformers
export TOKENIZERS_PARALLELISM=false
export PYTHONUNBUFFERED=1
export TRANSFORMERS_NO_ADVISORY_WARNINGS=1

STYLES="${STYLES:-0.2,0.5,0.8}"
DATA_OUT="${DATA_OUT:-sft_8b/results/day8_sft_data}"
TRAIN_OUT="${TRAIN_OUT:-sft_8b/results/day8_lora_run}"
EVAL_FRAC="${EVAL_FRAC:-0.10}"
INTENT_BALANCE_MODE="${INTENT_BALANCE_MODE:-oversample_to_anchor}"
MAX_INTENT_REPEAT="${MAX_INTENT_REPEAT:-32}"

mkdir -p "$DATA_OUT" "$TRAIN_OUT"


