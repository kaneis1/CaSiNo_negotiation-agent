# LSBATCH: User input
#!/bin/bash
#BSUB -J sft8b_bayes_p3
#BSUB -P acc_lin_lab
#BSUB -q gpu
#BSUB -gpu "num=1"
#BSUB -R "h100nvl rusage[mem=40000] span[hosts=1]"
#BSUB -n 4
