# Day 9 distilled-student evaluation (Protocol 3 / gold history).
#
# One style token per run. Baseline and Bayesian teacher already have their
# own full-run scripts; this is the student companion job so the three models
# can be launched in parallel.
#
# Submit:
#   bsub < sft_8b/scripts/run_day9_student_eval.lsf
#
# Override knobs:
#   bsub -env "all,STYLE_TOKEN=balanced,MAX_DIALOGUES=150" \
#        < sft_8b/scripts/run_day9_student_eval.lsf

set -eo pipefail

REPO_ROOT="/sc/arion/projects/lin_lab/complexbehavior/CaSino"
cd "$REPO_ROOT"

unset PYTHONPATH
set +u
source /hpc/packages/minerva-rocky9/miniforge3/26.1.1-3/miniforge/etc/profile.d/conda.sh
conda activate casino
set -u
hash -r

CASINO_PY=/sc/arion/work/cuiz02/conda-envs/envs/casino/bin/python

export HF_HOME=/sc/arion/scratch/cuiz02/hf_cache
export TRANSFORMERS_CACHE=$HF_HOME/transformers
export HUGGINGFACE_HUB_CACHE=$HF_HOME/hub
export TOKENIZERS_PARALLELISM=false
export PYTHONUNBUFFERED=1

BASE_MODEL="${BASE_MODEL:-/sc/arion/scratch/cuiz02/hf_cache/transformers/Meta-Llama-3.1-8B-Instruct}"
ADAPTER="${ADAPTER:-sft_8b/results/day8_lora_run/lora_best}"
DATA="${DATA:-data/casino_test.json}"
ANNOTATIONS="${ANNOTATIONS:-CaSiNo/data/casino_ann.json}"
MAX_DIALOGUES="${MAX_DIALOGUES:-150}"

